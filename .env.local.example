# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to Git!

# Email Configuration for Contact Form
# Follow the guide in docs/EMAIL_SETUP.md for detailed setup instructions

# Gmail Configuration (Recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=your-email@gmail.com
CONTACT_EMAIL=aankit.sssingh@gmail.com

# Alternative: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=your-verified-sender@domain.com
# CONTACT_EMAIL=your-email@domain.com

# Alternative: Outlook/Hotmail
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password
# SMTP_FROM=your-email@outlook.com
# CONTACT_EMAIL=your-email@outlook.com