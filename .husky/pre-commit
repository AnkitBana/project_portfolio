#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Security check for credentials
echo "🔍 Running security checks..."

# Check for .env files
if git diff --cached --name-only | grep -E "\.env$|\.env\.local$" > /dev/null 2>&1; then
    echo "❌ ERROR: Attempting to commit .env file!"
    echo "   .env files should never be committed to Git"
    echo "   Please remove them: git reset HEAD .env*"
    exit 1
fi

# Check for credential patterns, excluding documentation and examples
# Get changed files excluding docs and example patterns
CHANGED_FILES=$(git diff --cached --name-only | grep -vE "docs/|\.md$|example|\.bat$")

if [ -n "$CHANGED_FILES" ]; then
    # Check for real credentials in non-documentation files
    if git diff --cached -- $CHANGED_FILES | grep -iE "password.*=.*['\"][a-zA-Z0-9]{8,}['\"]" | grep -vE "your_.*_here|example|placeholder|process\.env|mypassword" > /dev/null 2>&1; then
        echo "❌ ERROR: Potential real password detected in code!"
        echo "   Please use environment variables instead"
        exit 1
    fi

    if git diff --cached -- $CHANGED_FILES | grep -iE "SMTP_PASS.*=.*['\"][a-zA-Z0-9]{8,}['\"]" | grep -vE "your_.*_here|example|placeholder|process\.env" > /dev/null 2>&1; then
        echo "❌ ERROR: Potential real SMTP password detected!"
        echo "   Please use environment variables instead"
        exit 1
    fi
fi

echo "✅ Security check passed!"

